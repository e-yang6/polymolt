# ──────────────────────────────────────────────────────────────────────────
# PolyMolt Frontend — Environment Variables
# Copy to .env.local and fill in real values:  cp .env.example .env.local
# ──────────────────────────────────────────────────────────────────────────

# Backend API URL — used by client-side code (browser → backend)
# Local: http://localhost:8000   Production: your Cloud Run URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Server-side backend URL — used by Next.js API routes (server → backend)
BACKEND_URL=http://127.0.0.1:8000

# Mapbox access token (required for map page)
NEXT_PUBLIC_MAPBOX_TOKEN=
