# ──────────────────────────────────────────────────────────────────────────
# PolyMolt Backend — Environment Variables
# Copy to .env and fill in real values:  cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────

# ── OpenAI / HuggingFace proxy ───────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=                          # leave blank for api.openai.com
CHAT_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small
CHAT_MAX_TOKENS=4096

# ── Google Gemini (embeddings + optional chat) ───────────────────────────
GOOGLE_API_KEY=

# ── IBM Db2 on Cloud ────────────────────────────────────────────────────
# Format: DATABASE=bludb;HOSTNAME=…;PORT=…;PROTOCOL=TCPIP;UID=…;PWD=…;Security=SSL
DB2_DSN=

# ── Astra DB — Agents RAG (sample_rag collection) ───────────────────────
ASTRA_DB_API_ENDPOINT=
ASTRA_DB_APPLICATION_TOKEN=
ASTRA_DB_KEYSPACE=default_keyspace

# ── Astra DB — Orchestrator RAG (news_rag collection) ───────────────────
ASTRA_DB_ORCHESTRATOR_API_ENDPOINT=
ASTRA_DB_ORCHESTRATOR_APPLICATION_TOKEN=
ASTRA_DB_ORCHESTRATOR_KEYSPACE=default_keyspace

# ── Upstash Redis (caching) ─────────────────────────────────────────────
# Get these from: https://console.upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Deployment ───────────────────────────────────────────────────────────
# PORT is set automatically by Cloud Run; override locally if needed
PORT=8080
# Comma-separated allowed origins for CORS (frontend URLs)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://http://polymolt.vercel.app
